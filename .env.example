# Orchestrator Configuration
HOST=0.0.0.0
ORCHESTRATOR_PORT=8001
AGENT_PORT=8003

# Public-facing URL (used for A2A agent cards and OAuth callbacks)
# Local dev: http://127.0.0.1:8001  |  Production: https://your-domain.com
BACKEND_PUBLIC_URL=http://localhost:8001
PUBLIC_BASE_URL=http://localhost:8001

# OpenAI-compatible LLM
# These are the **operator default** credentials, used for users who
# have NOT configured their own LLM subscription via the in-app
# "LLM Settings" panel (feature 006-user-llm-config). Users with
# personal credentials override these for their own calls; their
# personal credentials are NEVER persisted server-side and are billed
# to their own provider account. Server-initiated background jobs
# (e.g. the daily feedback quality / proposals job) always use these
# defaults regardless of any connected user's personal config.
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=
KNOWLEDGE_LLM_MODEL=
KNOWLEDGE_SYNTHESIS_INTERVAL=1800
KNOWLEDGE_MIN_INTERACTIONS=20

# Auto-start agents
AUTO_START_AGENTS=true

# Default owner for newly registered agents (auto-assigned on first connect)
DEFAULT_AGENT_OWNER= # email address, e.g. test@test.com

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=astralbody
DB_USER=astral
DB_PASSWORD=astral_dev

# Debug
DEBUG=true

# Feature Flags (true/false — controls new orchestrator features)
FF_DENIAL_LOOP_DETECTION=true
FF_TOOL_CONCURRENCY_SAFETY=true
FF_MESSAGE_COMPACTION=false
FF_PROGRESS_STREAMING=false
FF_HOOK_SYSTEM=false
FF_TASK_STATE_MACHINE=false
FF_COORDINATOR_MODE=false
FF_KNOWLEDGE_SYNTHESIS=false
FF_LIVE_STREAMING=false
FF_TOOL_STREAMING=true

# ── Agentic platform (features 027–031) ─────────────────────────────────────
FF_AGENTIC_CREATION=true        # orchestrator meta-tools create/extend agents on a gap
FF_SCHEDULING_CHAT=true         # schedule_recurring_task meta-tool (consent-gated)
FF_SCHEDULER_EXECUTION=false    # FAIL-CLOSED: unattended job runs (lead-dev review required)
FF_MEMORY_CHAT=true             # remember / memory_search / memory_get meta-tools
FF_ATTACHMENT_AUTOPARSE=true    # eager admin-gated auto-parser creation for new file types

# ── 033 frontier capabilities (features 034–065) ────────────────────────────
# Values below are the in-code defaults (safe rollout); flip to true to enable.
# See specs/033-frontier-techniques-research/ and specs/065-orphaned-capability-wiring/.

# Wave-0: context engineering + prompt-injection datamarking
FF_CONTEXT_ENGINEERING=false
FF_DATAMARKING=false

# Security gates (deterministic; fail-closed when triggered)
FF_POLICY_ENGINE=false          # pre-action policy rule chain (needs POLICY_RULES)
FF_TAINT_TRACKING=false         # value-level taint/data-flow sink gate
FF_SANDBOX_CODEGEN=false        # rlimit/preexec sandbox for generated-agent subprocess (POSIX)
FF_REDTEAM_SELFTEST=false       # adversarial red-team gate before promoting a draft agent
FF_RUNTIME_SUPERVISOR=false     # intent-alignment + drafted-answer leak/PHI review
FF_HITL_HIGHRISK=false          # human confirmation for egress/irreversible tool calls
FF_FLOW_PATTERNS=false          # per-turn tool budget by flow classification
FF_MAS_DEFENSE=false            # scan inter-agent payloads for injection markers
FF_ASI_COVERAGE=false           # plan-deviation detection

# Living memory
FF_MEMORY_RECONCILE=true        # reconcile-don't-append memory writes
FF_MEMORY_LINKING=true          # linked memory notes + multi-hop recall
FF_MEMORY_PAGERANK=true         # personalized-PageRank associative retrieval
FF_MEMORY_MULTISIGNAL=true      # multi-signal retrieval scoring
FF_MEMORY_GUARD=true            # memory-poisoning defense (HMAC-signed fields)
FF_MEMORY_TEMPORAL=false        # temporal validity (as-of) + provenance
FF_MEMORY_FORGETTING=false      # reinforcement-on-recall + principled forgetting
FF_MEMORY_PERSONA=false         # evolving user persona
FF_PROJECT_MEMORY=false         # project-scoped memory partitioning
FF_SKILL_MEMORY=false           # induce/replay reusable tool-sequence recipes

# Self-improving orchestration
FF_MOA_DEBATE=false             # Mixture-of-Agents candidate panel + aggregation
FF_ASYNC_FANOUT=false           # batch oversized parallel tool waves
FF_DUAL_LEDGER=false            # task/progress ledger for self-correction
FF_DRAFT_ARCHIVE=false          # evolutionary draft archive + self-test skip
FF_AGENT_EVAL=false             # trajectory-evaluation metrics in the quality job

# Device adaptation & generative UI
FF_MODEL_ROUTER=false           # device-capability-aware model tier router (needs MODEL_TIERS)
FF_LIVE_VIEWPORT=false          # live viewport-targeted re-adaptation
FF_NATIVE_TARGETS=false         # route VOICE→SSML / explicit AOM render targets (else web)
FF_AOM_RENDERER=false           # accessibility-object-model renderer
FF_GENERATIVE_PRIMITIVES=false  # gated generative UI primitives
FF_LOD_LADDER=false             # level-of-detail content ladder per device
FF_ADAPTIVE_OBJECTIVES=false    # device-fit objectives bias in the UI designer
FF_UI_DESIGNER_A11Y=false       # accessibility audit in the UI-designer lint stage
FF_PROVENANCE_SURFACING=true    # provenance/grounding footer on canvas components

# Adaptive UI designer (default ON; sub-stages individually gate-able)
FF_UI_DESIGNER=true
FF_UI_DESIGNER_SCORER=true
FF_UI_DESIGNER_ARCHETYPE=true
FF_UI_DESIGNER_LINT=true
FF_UI_DESIGNER_CONSERVATIVE=true
FF_UI_DESIGNER_TASKMODEL=false  # extra LLM task-model pre-pass (off by default)

# Dreaming (idle-time)
FF_SLEEPTIME_COMPUTE=false      # idle anticipatory precompute during the dreaming sweep
FF_PULSE_DIGEST=false           # "pulse" morning-digest chrome surface + topbar icon

# ── 033 operator settings (optional) ────────────────────────────────────────
# Single-use transaction-token signing key for the require_token policy effect
# (C-S8). Falls back to MEMORY_HMAC_KEY. Without one, require_token can only deny.
TXN_TOKEN_KEY=
# Policy rule chain (JSON list) consumed by FF_POLICY_ENGINE. Empty ⇒ allow-all.
POLICY_RULES=
# Model tier→model map (JSON) for FF_MODEL_ROUTER, e.g. {"small":"gpt-4o-mini"}.
MODEL_TIERS=
# Per-target host-config (JSON) for ROTE surface bounds.
ROTE_HOST_CONFIG=
# Draft-archive tunables (FF_DRAFT_ARCHIVE): max entries / self-test skip score.
DRAFT_ARCHIVE_MAX=200
DRAFT_ARCHIVE_SKIP_SCORE=0.85
# Adaptive-designer tunables.
UI_DESIGNER_MAX_ROUNDS=3
UI_DESIGNER_TIMEOUT_SECONDS=8


# Keycloak Authentication
KEYCLOAK_AUTHORITY= # e.g. https://iam.ai.uky.edu/realms/YourRealm
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
# The native desktop client (windows-client/) reuses this same KEYCLOAK_CLIENT_ID
# and exchanges its auth code through the BFF proxy (POST /auth/token); add a
# loopback redirect URI (http://127.0.0.1/*) to this Keycloak client for it.
AGENT_SERVICE_CLIENT_ID=
AGENT_SERVICE_CLIENT_SECRET=

# Feature 028 — environment posture. Production is the DEFAULT when unset:
# mock auth refuses to start and keyless agent connections are refused
# (fail closed). 'development' enables the local-dev allowances below.
ASTRAL_ENV=development

# Mock Auth (development only — requires ASTRAL_ENV=development since 028;
# a production-mode boot with mock auth on refuses to serve)
USE_MOCK_AUTH=true

# Fernet key encrypting durable web sessions at rest
# (falls back to OFFLINE_GRANT_ENC_KEY; REQUIRED outside development).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WEB_SESSION_ENC_KEY=

# Shared secret presented by agents at registration. REQUIRED for agents in
# production (registrations without it are refused, fail closed); optional in
# development (keyless local agents allowed).
AGENT_API_KEY=

# Speaches.ai (STT/TTS)
SPEACHES_URL=http://your-speaches-instance:4958

# Audit log — server-held HMAC secret used for the
# hash chain and for payload digests. MUST be set to a
# high-entropy value before deploying outside dev (the boot gate refuses
# this placeholder in production).
AUDIT_HMAC_SECRET=dev-audit-hmac-secret-change-me-in-prod
AUDIT_HMAC_KEY_ID=k1

# ── Production service settings (see docs/production-deployment.md) ─────────
# Reverse proxies allowed to set X-Forwarded-* (comma-separated IPs or '*').
# The orchestrator trusts these to derive https for the session cookie's
# `secure` flag and the OIDC redirect_uri. Default: loopback only.
FORWARDED_ALLOW_IPS=127.0.0.1

# CORS allowlist (comma-separated origins). Default: this deployment's own
# PUBLIC_BASE_URL/BACKEND_PUBLIC_URL — the web UI is same-origin since 026,
# so most deployments never need to set this.
#CORS_ORIGINS=

# Uvicorn log level (debug|info|warning|error). Production default: info.
LOG_LEVEL=info