# Orchestrator Configuration
HOST=0.0.0.0
ORCHESTRATOR_PORT=8001
AGENT_PORT=8003

# Public-facing URL (used for A2A agent cards and OAuth callbacks)
# Local dev: http://127.0.0.1:8001  |  Production: https://your-domain.com
BACKEND_PUBLIC_URL=http://127.0.0.1:8001
PUBLIC_BASE_URL=http://127.0.0.1:8001

# OpenAI-compatible LLM
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=

# Auto-start agents
AUTO_START_AGENTS=true

# Default owner for newly registered agents (auto-assigned on first connect)
DEFAULT_AGENT_OWNER= # e.g. admin@example.com

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=astralbody
DB_USER=astral
DB_PASSWORD=astral_dev

# Debug
DEBUG=true

# Keycloak Authentication
VITE_KEYCLOAK_AUTHORITY= # e.g. https://iam.example.com/realms/YourRealm
VITE_KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
AGENT_SERVICE_CLIENT_ID=
AGENT_SERVICE_CLIENT_SECRET=

# Mock Auth (set to true to skip Keycloak and use a dev user)
VITE_USE_MOCK_AUTH=true

# Speaches.ai (STT/TTS)
SPEACHES_URL= # e.g. http://your-speaches-instance:4958

# Keycloak Test Credentials (for integration/E2E testing)
KEYCLOAK_TEST_USER=
KEYCLOAK_TEST_PASSWORD=
