# Orchestrator Configuration
HOST=0.0.0.0
ORCHESTRATOR_PORT=8001
AGENT_PORT=8003

# Public-facing URL (used for A2A agent cards and OAuth callbacks)
# Local dev: http://127.0.0.1:8001  |  Production: https://your-domain.com
BACKEND_PUBLIC_URL=http://localhost:8001
PUBLIC_BASE_URL=http://localhost:8001

# LLM credentials — configured IN-APP, not here (feature 054-byo-llm-setup).
# The product ships with NO LLM credential and the legacy operator-default
# env vars (OPENAI_API_KEY / OPENAI_BASE_URL / LLM_MODEL / KNOWLEDGE_LLM_MODEL)
# are INERT — setting them has no effect. Each user connects their own
# provider via the mandatory first-run dialog (stored per-user, API key
# encrypted at rest under CREDENTIAL_ENCRYPTION_KEY); an admin configures
# the deployment-wide "System LLM" (Settings → System LLM) for background
# work (scheduled jobs, knowledge synthesis, codegen, compaction, combine).
KNOWLEDGE_SYNTHESIS_INTERVAL=1800
KNOWLEDGE_MIN_INTERACTIONS=20
# Per-user per-minute cap on the LLM connection-probe endpoints
# (/api/llm/test, /api/llm/list-models). Default: 20.
#LLM_PROBE_RATE_PER_MINUTE=20

# Auto-start agents
AUTO_START_AGENTS=true

# Default owner for newly registered agents (auto-assigned on first connect)
DEFAULT_AGENT_OWNER= # email address, e.g. test@test.com

# Database (PostgreSQL)
# Individual host/port/name/user/password vars build the connection string.
# Alternatively, set DATABASE_URL to a full libpq URI (takes precedence).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=astraldeep
DB_USER=astral
DB_PASSWORD=astral_dev
#DATABASE_URL=postgresql://localhost:5432/astraldeep

# Debug
DEBUG=true

# Feature Flags (true/false — controls new orchestrator features)
FF_DENIAL_LOOP_DETECTION=true
FF_TOOL_CONCURRENCY_SAFETY=true
FF_MESSAGE_COMPACTION=false
FF_PROGRESS_STREAMING=false
FF_HOOK_SYSTEM=false
FF_TASK_STATE_MACHINE=false
FF_COORDINATOR_MODE=false
FF_KNOWLEDGE_SYNTHESIS=false
FF_LIVE_STREAMING=false
FF_TOOL_STREAMING=false           # matches the code default (safe rollout, specs/001)
FF_AGENTIC_CREATION=true        # orchestrator meta-tools create/extend agents on a gap
FF_SCHEDULING_CHAT=true         # schedule_recurring_task meta-tool (consent-gated)
FF_SCHEDULER_EXECUTION=false    # FAIL-CLOSED: unattended job runs (lead-dev review required)
FF_MEMORY_CHAT=true             # remember / memory_search / memory_get meta-tools
FF_DESKTOP_CODEGEN=true         # offer_desktop_codegen meta-tool: download card for the Windows .exe
FF_ATTACHMENT_AUTOPARSE=true    # eager admin-gated auto-parser creation for new file types
FF_CONTEXT_ENGINEERING=false
FF_DATAMARKING=false
# Override the default number of spans the datamarking sanitizer processes
# (FF_DATAMARKING). Defaults to "false" (use the built-in default).
#DATAMARK_SANITIZE_SPANS=false
FF_POLICY_ENGINE=false          # pre-action policy rule chain (needs POLICY_RULES)
FF_TAINT_TRACKING=false         # value-level taint/data-flow sink gate
FF_SANDBOX_CODEGEN=false        # rlimit/preexec sandbox for generated-agent subprocess (POSIX)
FF_REDTEAM_SELFTEST=false       # adversarial red-team gate before promoting a draft agent
FF_RUNTIME_SUPERVISOR=false     # intent-alignment + drafted-answer leak/PHI review
FF_HITL_HIGHRISK=false          # human confirmation for egress/irreversible tool calls
FF_FLOW_PATTERNS=false          # per-turn tool budget by flow classification
FF_MAS_DEFENSE=false            # scan inter-agent payloads for injection markers
# HMAC key for MAS payload integrity (falls back to MEMORY_HMAC_KEY when unset).
# Optional in dev; recommended in production when FF_MAS_DEFENSE is on.
#MAS_MESSAGE_KEY=
FF_ASI_COVERAGE=false           # plan-deviation detection
FF_MEMORY_RECONCILE=true        # reconcile-don't-append memory writes
FF_MEMORY_LINKING=true          # linked memory notes + multi-hop recall
FF_MEMORY_PAGERANK=true         # personalized-PageRank associative retrieval
FF_MEMORY_MULTISIGNAL=true      # multi-signal retrieval scoring
FF_MEMORY_GUARD=true            # memory-poisoning defense (HMAC-signed fields)
FF_MEMORY_TEMPORAL=false        # temporal validity (as-of) + provenance
FF_MEMORY_FORGETTING=false      # reinforcement-on-recall + principled forgetting
FF_MEMORY_PERSONA=false         # evolving user persona
FF_PROJECT_MEMORY=false         # project-scoped memory partitioning
FF_SKILL_MEMORY=false           # induce/replay reusable tool-sequence recipes
FF_MOA_DEBATE=false             # Mixture-of-Agents candidate panel + aggregation
FF_ASYNC_FANOUT=false           # batch oversized parallel tool waves
FF_DUAL_LEDGER=false            # task/progress ledger for self-correction
FF_DRAFT_ARCHIVE=false          # evolutionary draft archive + self-test skip
FF_AGENT_EVAL=false             # trajectory-evaluation metrics in the quality job
FF_MODEL_ROUTER=false           # device-capability-aware model tier router (needs MODEL_TIERS)
FF_LIVE_VIEWPORT=false          # live viewport-targeted re-adaptation
FF_NATIVE_TARGETS=false         # route VOICE→SSML / explicit AOM render targets (else web)
FF_AOM_RENDERER=false           # accessibility-object-model renderer
FF_GENERATIVE_PRIMITIVES=false  # gated generative UI primitives
FF_LOD_LADDER=false             # level-of-detail content ladder per device
FF_ADAPTIVE_OBJECTIVES=false    # device-fit objectives bias in the UI designer
FF_UI_DESIGNER_A11Y=false       # accessibility audit in the UI-designer lint stage
FF_PROVENANCE_SURFACING=true    # provenance/grounding footer on canvas components
FF_UI_DESIGNER=true
FF_UI_DESIGNER_SCORER=true
FF_UI_DESIGNER_ARCHETYPE=true
FF_UI_DESIGNER_LINT=true
FF_UI_DESIGNER_CONSERVATIVE=true
FF_UI_DESIGNER_TASKMODEL=false  # extra LLM task-model pre-pass (off by default)
FF_DESIGNER_ALL_DEVICES=true    # 055: designer runs for native-origin turns (one post-done pass); off restores the native skip
FF_SLEEPTIME_COMPUTE=false      # idle anticipatory precompute during the dreaming sweep
FF_PULSE_DIGEST=false           # "pulse" morning-digest chrome surface + topbar icon
FF_A11Y=true                    # webrender ARIA landmark/role injection (default ON)
FF_INPROCESS_AGENTS=true        # run bundled agents in-process (no per-agent port); WS path is kill-switch
FF_SAFE_AGENTS=true             # owner-approved "safe" agents: default-deny→allow baseline (explicit opt-out still wins)
FF_SKILL_PACKS=true             # load authored technique skill packs into the system prompt (fail-open)
FF_SLASH_COMMANDS=true          # expand /help /agents /summarize /research /weather in chat (fail-open)
FF_RECURSIVE_DELEGATION=false   # 048: nested RFC 8693 act-token delegation chains (FAIL-CLOSED; single-hop path when off)
FF_LLM_FIRST_RUN=true           # 054: register-time mandatory provider-setup dialog push (kill switch
                                # for the PUSH only — server-side gate refusals are structural)
FF_FIRST_TURN_CONTRACT=true     # 055: wel_ welcome identities + client turn-start purge; the turn-start
                                # welcome-blanking ui_render is no longer sent (off restores both, byte-identical)
FF_STREAM_ARTIFACTS=true        # 055: bridge push-streams to workspace identities (component_id on stream
                                # frames; final state persists as a component). Off = ephemeral stream-<id> behavior
FF_COMPONENT_REFINE=true        # 055: component_refine/component_restore verbs, per-component version history,
                                # AND server-side provenance stamping (off = no affordance, honest refusal, no stamp)
FF_ARTIFACT_EXPORT=true         # 055: authed CSV/HTML export endpoints + client export affordances (off = routes 404)
FF_ARTIFACT_SHARING=false       # 055: FAIL-CLOSED public read-only snapshot share links (PHI-gated mint, hashed
                                # tokens, revocable). Off (default) = share routes 404, no share affordances
FF_BG_CONTINUITY=true           # 055: cross-device background-task continuity — task frames fan to every socket
                                # of the user, background turns mirror narrative + done to sockets on the chat,
                                # reconnect resume/replay. Off = originator-only frames, byte-identical
# The sixth 055 flag, FF_DESIGNER_ALL_DEVICES, lives with the UI-designer flags above.

# Single-use transaction-token signing key for the require_token policy effect
# (C-S8). Falls back to MEMORY_HMAC_KEY. Without one, require_token can only deny.
TXN_TOKEN_KEY=
# Policy rule chain (JSON list) consumed by FF_POLICY_ENGINE. Empty ⇒ allow-all.
POLICY_RULES=
# Model tier→model map (JSON) for FF_MODEL_ROUTER, e.g. {"small":"gpt-4o-mini"}.
MODEL_TIERS=
# Per-target host-config (JSON) for ROTE surface bounds.
ROTE_HOST_CONFIG=
# Draft-archive tunables (FF_DRAFT_ARCHIVE): max entries / self-test skip score.
DRAFT_ARCHIVE_MAX=200
DRAFT_ARCHIVE_SKIP_SCORE=0.85
# Adaptive-designer tunables. Default rounds is 1 since feature 052 (components
# render before the designer runs; raise to re-enable multi-round refinement).
UI_DESIGNER_MAX_ROUNDS=1
UI_DESIGNER_TIMEOUT_SECONDS=8


# Keycloak Authentication
# KEYCLOAK_AUTHORITY is the primary var (full realm URL). Retired
# VITE_-prefixed aliases still backfill one-way with a deprecation warning.
KEYCLOAK_AUTHORITY= # e.g. https://iam.ai.uky.edu/realms/YourRealm
KEYCLOAK_CLIENT_ID=astral-frontend   # the web (confidential) client
KEYCLOAK_CLIENT_SECRET=
# Optional: if KEYCLOAK_TOKEN_URL is unset, the orchestrator builds it from
# KEYCLOAK_URL + KEYCLOAK_REALM (defaults: '' / 'astral'). Set these only if
# your token endpoint differs from the standard realm path.
#KEYCLOAK_URL=
#KEYCLOAK_REALM=astral
#KEYCLOAK_TOKEN_URL=
# Additional first-party OIDC client ids (comma-separated) whose access tokens
# the orchestrator accepts at the WS/REST gates, beyond KEYCLOAK_CLIENT_ID.
# The native Windows client (windows-client/) authenticates with its OWN
# dedicated PUBLIC client and its tokens carry azp=astral-desktop — list it here.
# The native Android client (android-client/) uses its own PUBLIC client,
# astral-mobile (azp=astral-mobile) — list it too. Comma-separated.
# The native Apple clients (apple-clients/, feature 051) REUSE the shared
# public clients rather than dedicated ones: iOS shares astral-mobile with
# Android, macOS shares astral-desktop with Windows, and only the watch has a
# dedicated client, astral-watch — so deploying the Apple clients adds no new
# azp beyond astral-watch. Empty ⇒ web client only.
# Setup: docs/keycloak-windows-client-setup.md,
# docs/keycloak-android-client-setup.md, docs/keycloak-realm-settings.md §051
KEYCLOAK_ALLOWED_AZP= # e.g. astral-desktop,astral-mobile,astral-watch
AGENT_SERVICE_CLIENT_ID=
AGENT_SERVICE_CLIENT_SECRET=

# ── Watch QR sign-in (feature 051, RFC 8628 device-login broker) ───────────
# Default ON; the broker still fails closed unless the realm advertises
# device_authorization_endpoint AND the client below has the Device
# Authorization Grant enabled. Endpoints: /api/auth/device/{start,poll,refresh}
FF_DEVICE_LOGIN=true
# Public clients allowed to use the device grant (comma-separated; must also
# appear in KEYCLOAK_ALLOWED_AZP). Watch-only by default.
KEYCLOAK_DEVICE_CLIENTS=astral-watch
# Max /api/auth/device/start requests per client address per minute.
DEVICE_LOGIN_START_RATE=10

# ── Desktop codegen download (feature 039) ─────────────────────────────────
# The offer_desktop_codegen meta-tool fetches the latest GitHub Release of the
# Windows client to build a verified download card. Bounded in-process cache.
DESKTOP_RELEASE_REPO=AstralDeep/AstralDeep
DESKTOP_RELEASE_TTL_SECONDS=300
# Optional: raises the GitHub API rate limit when resolving the latest release.
#GITHUB_TOKEN=

# mock auth refuses to start and keyless agent connections are refused
# (fail closed). 'development' enables the local-dev allowances below.
ASTRAL_ENV=development

# Mock Auth (development only — requires ASTRAL_ENV=development since 028;
# a production-mode boot with mock auth on refuses to serve)
USE_MOCK_AUTH=true

# Fernet key encrypting durable web sessions at rest
# (falls back to OFFLINE_GRANT_ENC_KEY; REQUIRED outside development).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WEB_SESSION_ENC_KEY=

# Dedicated HMAC key for signing session cookies. When unset, the
# orchestrator derives one from WEB_SESSION_ENC_KEY/OFFLINE_GRANT_ENC_KEY
# via HKDF (key separation). Set explicitly when cookie-signing must be
# independent of the encryption key. Required for multi-process production.
WEB_SESSION_SECRET=

# Fernet key encrypting stored OAuth refresh tokens for offline grants
# (scheduling/unattended jobs). REQUIRED outside development; its absence
# fails safe (scheduling refuses to store tokens unencrypted).
OFFLINE_GRANT_ENC_KEY=

# Fernet key encrypting agent-scoped OAuth credentials at rest.
# REQUIRED outside development (the credential manager warns if unset).
CREDENTIAL_ENCRYPTION_KEY=

# HMAC signing key for memory-poisoning defense, MAS payload integrity,
# and transaction tokens (TXN_TOKEN_KEY falls back to this). Optional in
# dev (features degrade to unsigned mode); recommended in production.
MEMORY_HMAC_KEY=

# Shared secret presented by agents at registration. REQUIRED for agents in
# production (registrations without it are refused, fail closed); optional in
# development (keyless local agents allowed).
AGENT_API_KEY=

# Override whether RFC 8693 delegated tokens are required for agent dispatch.
# Default: required in production (ASTRAL_ENV != development), optional in dev.
# Set to "false" to accept unscoped dispatch (dev only — security risk in prod).
#DELEGATION_REQUIRED=

# Path to the agent's EC P-256 private key for ECIES credential decryption.
# Override for non-standard key locations; default resolves to
# backend/data/agent_keys/<agent_id>.pem (bind-mounted in docker-compose).
#AGENT_KEY_PATH=

# Speaches.ai (STT/TTS)
SPEACHES_URL=http://your-speaches-instance:4958
# Override the default STT/TTS models if your Speaches instance uses others.
#SPEACHES_STT_MODEL=Systran/faster-whisper-large-v3
#SPEACHES_TTS_MODEL=speaches-ai/Kokoro-82M-v1.0-ONNX-int8

# Audit log — server-held HMAC secret used for the
# hash chain and for payload digests. MUST be set to a
# high-entropy value before deploying outside dev (the boot gate refuses
# this placeholder in production).
AUDIT_HMAC_SECRET=dev-audit-hmac-secret-change-me-in-prod
AUDIT_HMAC_KEY_ID=k1

# ── Production service settings (see docs/production-deployment.md) ─────────
# Reverse proxies allowed to set X-Forwarded-* (comma-separated IPs or '*').
# The orchestrator trusts these to derive https for the session cookie's
# `secure` flag and the OIDC redirect_uri. Default: loopback only.
FORWARDED_ALLOW_IPS=127.0.0.1

# CORS allowlist (comma-separated origins). Default: this deployment's own
# PUBLIC_BASE_URL/BACKEND_PUBLIC_URL — the web UI is same-origin since 026,
# so most deployments never need to set this.
#CORS_ORIGINS=

# Uvicorn log level (debug|info|warning|error). Production default: info.
LOG_LEVEL=info

# Audit log retention period in days (default: 2192 ≈ 6 years).
AUDIT_RETENTION_DAYS=2192

# Comma-separated list of private/internal hostnames or IPs that external
# agents are allowed to reach via shared/external_http (SSRF defense).
# Empty (default) ⇒ all private addresses blocked.
#EXTERNAL_AGENT_ALLOWED_PRIVATE_HOSTS=

# ── Operational tunables ───────────────────────────────────────────────────
# Max concurrent agents the orchestrator will register/start (default: 10).
#MAX_AGENTS=10
# Attachment upload root directory (default: backend/data/uploads).
#ATTACHMENT_UPLOAD_ROOT=
# Max days an offline grant token is valid (default: 365; also caps
# interactive session lifetime in seconds for the web UI).
#OFFLINE_GRANT_MAX_DAYS=365
# Override the LLM reasoning effort ("low"/"medium"/"high") for models that
# support it; unset ⇒ model default.
#LLM_REASONING_EFFORT=
# Auth revocation queue retry interval in seconds (default: 60).
#AUTH_REVOCATION_RETRY_SECONDS=60
# UI-designer layout adoption margin — ratio above which a layout is adopted
# over the flat default (default: 0.5).
#UI_DESIGNER_ADOPT_MARGIN=
# Feedback quality job cadence (seconds) and pass-k (default: 86400 / 2).
#FEEDBACK_QUALITY_JOB_INTERVAL=86400
#FEEDBACK_QUALITY_JOB_WARMUP=60
#FEEDBACK_QUALITY_PASS_K=2
# Override the knowledge root directory that feedback proposals read/write
# (defaults to backend/knowledge). Set to relocate the knowledge base.
#FEEDBACK_KNOWLEDGE_ROOT=
# Red-team adversarial scenario library override (JSON list; see orchestrator/redteam.py).
#REDTEAM_SCENARIOS=
# Default cron schedule for the dreaming/sleep-time consolidation sweep.
#DREAMING_DEFAULT_CRON=0 3 * * *
# External agents to auto-register at startup (comma-separated agent-id@URL).
#A2A_EXTERNAL_AGENTS=
# Verification harness base URL for external-mode SDUI verification runs.
#ASTRAL_VERIFY_BASE_URL=

# ── Feature 052 performance knobs (all optional; defaults shown) ──────────────
# Database connection pool (replaces connect-per-query). Keep DB_POOL_MAX x
# number of orchestrator processes under Postgres max_connections.
DB_POOL_MIN=2
DB_POOL_MAX=10
# Uncomment to revert to the legacy connect-per-query path (kill switch):
#DB_POOL_DISABLE=1
# Stream the narrative answer token-by-token to clients (set false to disable).
FF_LLM_STREAMING=true
# Pre-warm the PHI analyzer at boot so the first personalization write doesn't stall.
FF_PHI_WARM=true
# Background refresh interval (seconds) for the Keycloak signing keys warmed at boot.
JWKS_REFRESH_SECONDS=500

# ── Docker / procfs remapping (general agent host-info tools) ────────────────
# When the orchestrator runs inside a container, /proc reflects the container's
# PID namespace, not the host. Set HOST_PROC to the bind-mounted host procfs
# (e.g. /host/proc) so psutil-based tools in agents/general read real host data.
# PSUTIL_PROCFS_PATH is set automatically from HOST_PROC (psutil ≥6.x reads it).
#HOST_PROC=
#PSUTIL_PROCFS_PATH=

# ── Test / CI knobs (do NOT set in production) ───────────────────────────────
# Skip the concurrent-surface perf tests (ASTRAL_SKIP_PERF=1).
#ASTRAL_SKIP_PERF=
# Floor (ms) and worker count for the concurrent-surface perf tests.
#PERF_CONCURRENT_FLOOR_MS=250
#PERF_CONCURRENT_OPENS=20
# Fail (not just warn) on event-loop-blocking detected by the guard plugin.
#LOOP_GUARD_ENFORCE=
# Load real (not canned) attack cases in the security-benchmark harness.
#ASTRAL_BENCH_LOAD_REAL=