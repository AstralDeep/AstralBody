{
  "version": 1,
  "description": "Committed UI-protocol manifest (feature 044). Single source for the server->client WS frame vocabulary, the ui_event action vocabulary, and the component vocabulary. Backend, Windows, and Android test suites all assert against this file; adding a frame type, action, or component type REQUIRES editing it in the same PR (guards fail otherwise). See specs/044-native-client-parity/contracts/ui-protocol.md.",
  "frame_contracts": {
    "admission_refusal": {
      "type": "error",
      "exact_fields": [
        "type",
        "submission_id",
        "accepted",
        "code",
        "message",
        "retryable",
        "retry_after_ms"
      ],
      "submission_id": "canonical_lowercase_uuid4",
      "accepted": false,
      "additional_fields": false,
      "codes": [
        "capacity_exceeded",
        "registration_required",
        "registration_timeout",
        "idempotency_conflict",
        "connection_closing",
        "service_draining",
        "invalid_input",
        "registration_queue_full",
        "operation_failed"
      ]
    }
  },
  "push_types": [
    {"name": "agent_bundle_deliver", "category": "agents"},
    {"name": "agent_creation_progress", "category": "creation"},
    {"name": "agent_host_inventory_reconciled", "category": "agents"},
    {"name": "agent_host_registered", "category": "agents"},
    {"name": "agent_host_registration_refused", "category": "agents"},
    {"name": "agent_lifecycle", "category": "agents"},
    {"name": "agent_list", "category": "bootstrap"},
    {"name": "agent_offline", "category": "agents"},
    {"name": "agent_permissions", "category": "permissions"},
    {"name": "agent_permissions_updated", "category": "permissions"},
    {"name": "agent_registered", "category": "bootstrap"},
    {"name": "agent_stop", "category": "agents"},
    {"name": "agent_tunnel", "category": "agents"},
    {"name": "audit_append", "category": "audit"},
    {"name": "auth_required", "category": "auth"},
    {"name": "chat_created", "category": "chat"},
    {"name": "chat_deleted", "category": "chat"},
    {"name": "chat_loaded", "category": "chat"},
    {"name": "chat_status", "category": "chat"},
    {"name": "chat_step", "category": "chat"},
    {"name": "chrome_menu", "category": "chrome"},
    {"name": "chrome_render", "category": "chrome"},
    {"name": "chrome_surface", "category": "chrome"},
    {"name": "combine_error", "category": "component_verbs"},
    {"name": "combine_status", "category": "component_verbs"},
    {"name": "component_deleted", "category": "component_verbs"},
    {"name": "component_save_error", "category": "component_verbs"},
    {"name": "component_saved", "category": "component_verbs"},
    {"name": "components_combined", "category": "component_verbs"},
    {"name": "components_condensed", "category": "component_verbs"},
    {"name": "conversation_commit_ready", "category": "chat"},
    {"name": "conversation_snapshot", "category": "chat"},
    {"name": "error", "category": "error", "shapes": ["code+message", "payload.message", "message"]},
    {"name": "heartbeat", "category": "chat"},
    {"name": "history_list", "category": "chat"},
    {"name": "llm_config_ack", "category": "llm"},
    {"name": "llm_usage_report", "category": "llm"},
    {"name": "notification", "category": "notification"},
    {"name": "operation_status", "category": "operations"},
    {"name": "rote_config", "category": "bootstrap"},
    {"name": "saved_components_list", "category": "component_verbs"},
    {"name": "stream_data", "category": "streaming"},
    {"name": "stream_error", "category": "streaming"},
    {"name": "stream_list", "category": "streaming"},
    {"name": "stream_subscribed", "category": "streaming"},
    {"name": "stream_unsubscribed", "category": "streaming"},
    {"name": "system_config", "category": "bootstrap"},
    {"name": "task_completed", "category": "chat"},
    {"name": "task_started", "category": "chat"},
    {"name": "tool_progress", "category": "chat"},
    {"name": "ui_append", "category": "canvas"},
    {"name": "ui_render", "category": "canvas"},
    {"name": "ui_stream_data", "category": "streaming"},
    {"name": "ui_update", "category": "canvas"},
    {"name": "ui_upsert", "category": "canvas"},
    {"name": "user_message_acked", "category": "chat"},
    {"name": "user_preferences", "category": "bootstrap"},
    {"name": "workspace_timeline_mode", "category": "chat"}
  ],
  "accept_actions": [
    "agent_tunnel",
    "authorize_action", "cancel_task", "chat_message", "chrome_admin_proposal_decide",
    "chrome_admin_step_archive", "chrome_admin_step_restore", "chrome_admin_step_save",
    "chrome_agent_enabled", "chrome_attachment_delete", "chrome_audit_page",
    "chrome_author_advance", "chrome_author_analyze", "chrome_author_clarify",
    "chrome_author_delete", "chrome_author_draft", "chrome_author_edit",
    "chrome_author_generate", "chrome_author_list", "chrome_author_plan",
    "chrome_author_revise", "chrome_author_specify", "chrome_author_start",
    "chrome_author_tasks", "chrome_close",
    "chrome_credential_delete", "chrome_credentials_save", "chrome_draft_create",
    "chrome_dreaming_toggle", "chrome_dreaming_trigger", "chrome_job_delete",
    "chrome_job_pause", "chrome_job_resume", "chrome_job_run_now", "chrome_llm_clear",
    "chrome_llm_models", "chrome_llm_save", "chrome_llm_sys_clear", "chrome_llm_sys_models",
    "chrome_llm_sys_save", "chrome_llm_sys_test", "chrome_llm_test", "chrome_memory_delete",
    "chrome_memory_update", "chrome_open", "chrome_perms_save", "chrome_profile_save",
    "chrome_safe_set", "chrome_skill_toggle", "chrome_theme_preset", "chrome_tour_event",
    "chrome_visibility_set", "chrome_workspace_timeline_live", "chrome_workspace_timeline_view",
    "combine_components", "component_action", "component_feedback", "component_refine",
    "component_restore", "condense_components",
    "delete_saved_component", "discover_agents", "draft_approve", "draft_discard",
    "draft_refine", "enable_recommended_agents", "feedback_amend", "feedback_retract",
    "get_agent_permissions", "get_dashboard", "get_history", "get_saved_components",
    "load_chat", "new_chat", "register_external_agent", "revision_apply", "revision_discard",
    "save_component", "save_theme", "schedule_decision", "set_agent_permissions",
    "stream_list", "stream_subscribe", "stream_unsubscribe", "table_paginate",
    "update_device", "watch_task"
  ],
  "client_local_actions": ["attach_existing"],
  "additive_fields": [
    {
      "field": "speech",
      "shape": {"ssml": "string", "text": "string"},
      "carried_on": ["ui_render", "ui_upsert"],
      "scope": "watch-profile sockets only; absent when the rendition is unspeakable",
      "introduced_by": "051-apple-native-clients (FR-036)",
      "contract": "specs/051-apple-native-clients/contracts/spoken-rendition.md"
    },
    {
      "field": "component_id",
      "shape": "string",
      "carried_on": ["ui_stream_data", "stream_subscribed"],
      "scope": "present when the stream is bridged to a workspace component identity; absent on legacy/narrative streams",
      "introduced_by": "055-uniform-artifacts (FR-010)",
      "contract": "specs/055-uniform-artifacts/contracts/wire-contract.md"
    },
    {
      "field": "agent_host",
      "shape": {
        "host_id": "uuid4",
        "supported_runtime_contract_versions": ["positive integer"],
        "runtime_lock_sha256": "64 lowercase hex",
        "platform": "windows | macos",
        "client_version": "strict SemVer"
      },
      "carried_on": ["register_ui"],
      "scope": "authenticated desktop host advertisement; the client never supplies host_session_id",
      "introduced_by": "060-runtime-reliability-hardening (FR-019)",
      "contract": "specs/060-runtime-reliability-hardening/contracts/personal-agent-runtime.md"
    },
    {
      "field": "connection_generation",
      "shape": "uuid4",
      "carried_on": ["register_ui", "conversation_commit_ready", "conversation_snapshot", "operation_status", "ui_render", "ui_update", "ui_upsert", "ui_append", "ui_stream_data"],
      "scope": "fresh equality fence for one WebSocket connection attempt",
      "introduced_by": "060-runtime-reliability-hardening (FR-029, FR-032)",
      "contract": "specs/060-runtime-reliability-hardening/contracts/conversation-continuity.md"
    },
    {
      "field": "request_generation",
      "shape": "uuid4",
      "carried_on": ["conversation_commit_ready", "conversation_snapshot", "operation_status", "ui_render", "ui_update", "ui_upsert", "ui_append", "ui_stream_data"],
      "scope": "fresh equality fence for one hydration or commit request",
      "introduced_by": "060-runtime-reliability-hardening (FR-029, FR-032)",
      "contract": "specs/060-runtime-reliability-hardening/contracts/conversation-continuity.md"
    },
    {
      "field": "chat_id",
      "shape": "uuid4",
      "carried_on": ["conversation_commit_ready", "conversation_snapshot", "operation_status", "ui_render", "ui_update", "ui_upsert", "ui_append", "ui_stream_data"],
      "scope": "owner-validated active chat; operation_status uses explicit null for surface-only work",
      "introduced_by": "060-runtime-reliability-hardening (FR-029, FR-032)",
      "contract": "specs/060-runtime-reliability-hardening/contracts/conversation-continuity.md"
    },
    {
      "field": "base_render_revision",
      "shape": "unsigned 64-bit integer",
      "carried_on": ["ui_render", "ui_update", "ui_upsert", "ui_append", "ui_stream_data"],
      "scope": "disposable preview overlay; must equal the current committed revision",
      "introduced_by": "060-runtime-reliability-hardening (FR-029)",
      "contract": "specs/060-runtime-reliability-hardening/contracts/conversation-continuity.md"
    },
    {
      "field": "frame_sequence",
      "shape": "unsigned 64-bit integer",
      "carried_on": ["ui_render", "ui_update", "ui_upsert", "ui_append", "ui_stream_data"],
      "scope": "strictly increasing within a chat/connection/request overlay generation",
      "introduced_by": "060-runtime-reliability-hardening (FR-029)",
      "contract": "specs/060-runtime-reliability-hardening/contracts/conversation-continuity.md"
    },
    {
      "field": "resume",
      "shape": {
        "schema_version": 1,
        "active_chat_id": "uuid4",
        "request_generation": "uuid4"
      },
      "carried_on": ["register_ui"],
      "scope": "optional account-scoped active-chat hydration request",
      "introduced_by": "060-runtime-reliability-hardening (FR-027, FR-029)",
      "contract": "specs/060-runtime-reliability-hardening/contracts/conversation-continuity.md"
    },
    {
      "field": "capabilities.personal_agent_host.macos",
      "shape": {
        "supported": "boolean",
        "runtime_contract_versions": ["positive integer"],
        "source_feature": "059 | null"
      },
      "carried_on": ["system_config", "GET /api/dashboard"],
      "scope": "immutable candidate-owned applicability; missing or malformed is blocking",
      "introduced_by": "060-runtime-reliability-hardening (FR-050)",
      "contract": "specs/060-runtime-reliability-hardening/contracts/personal-agent-runtime.md"
    }
  ],
  "component_types": [
    "alert", "audio", "badge", "bar_chart", "button", "card", "chat_history", "code",
    "collapsible", "color_picker", "container", "divider", "download_card", "file_download",
    "file_upload", "generative", "grid", "hero", "image", "input", "keyvalue", "line_chart",
    "list", "metric", "param_picker", "pie_chart", "plotly_chart", "progress", "rating",
    "skeleton", "table", "tabs", "text", "theme_apply", "timeline"
  ]
}
