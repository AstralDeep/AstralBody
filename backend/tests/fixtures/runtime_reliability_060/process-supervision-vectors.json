{
  "schema_version": 1,
  "contract": "astraldeep-process-supervision-060",
  "description": "Platform-neutral process behaviors shared by the backend and packaged Windows supervisor conformance tests.",
  "limits": {
    "read_chunk_bytes": 16384,
    "maximum_logical_line_bytes": 65536,
    "ring_capacity_bytes_per_stream": 262144,
    "ring_capacity_bytes_per_process": 524288,
    "termination_deadline_ms": 5000
  },
  "vectors": [
    {
      "id": "dual-stream-high-output",
      "behavior": {
        "kind": "emit_then_exit",
        "stdout": {
          "line_count": 4096,
          "line_bytes": 128
        },
        "stderr": {
          "line_count": 4096,
          "line_bytes": 128
        },
        "exit_code": 0
      },
      "action": {
        "kind": "wait_for_exit"
      },
      "expected": {
        "exit_code": 0,
        "stdout_consumed_continuously": true,
        "stderr_consumed_continuously": true,
        "stdout_dropped_bytes_minimum": 1,
        "stderr_dropped_bytes_minimum": 1,
        "reader_threads_joined": true,
        "pipes_closed": true
      }
    },
    {
      "id": "oversized-logical-line",
      "behavior": {
        "kind": "emit_then_exit",
        "stdout": {
          "line_count": 1,
          "line_bytes": 131072
        },
        "stderr": {
          "line_count": 0,
          "line_bytes": 0
        },
        "exit_code": 0
      },
      "action": {
        "kind": "wait_for_exit"
      },
      "expected": {
        "exit_code": 0,
        "stdout_overlong_lines_minimum": 1,
        "maximum_retained_line_bytes": 65536,
        "reader_threads_joined": true,
        "pipes_closed": true
      }
    },
    {
      "id": "one-pipe-eof-other-continues",
      "behavior": {
        "kind": "close_one_stream_then_emit",
        "close_stream": "stdout",
        "continuing_stream": "stderr",
        "continuing_line_count": 128,
        "continuing_line_bytes": 64,
        "delay_after_close_ms": 50,
        "exit_code": 0
      },
      "action": {
        "kind": "wait_for_exit"
      },
      "expected": {
        "exit_code": 0,
        "continuing_stream_complete": true,
        "reader_threads_joined": true,
        "pipes_closed": true
      }
    },
    {
      "id": "descendant-tree-stop",
      "behavior": {
        "kind": "parent_with_descendant",
        "parent_mode": "periodic_output",
        "descendant_mode": "periodic_output",
        "period_ms": 10
      },
      "action": {
        "kind": "stop",
        "after_ms": 100
      },
      "expected": {
        "complete_process_tree_terminated": true,
        "cleanup_within_ms": 5000,
        "reader_threads_joined": true,
        "pipes_closed": true
      }
    },
    {
      "id": "descendant-tree-quit",
      "behavior": {
        "kind": "parent_with_descendant",
        "parent_mode": "cooperative_wait",
        "descendant_mode": "cooperative_wait"
      },
      "action": {
        "kind": "quit",
        "after_ms": 100
      },
      "expected": {
        "complete_process_tree_terminated": true,
        "cleanup_within_ms": 5000,
        "reader_threads_joined": true,
        "pipes_closed": true
      }
    },
    {
      "id": "crash-after-output",
      "behavior": {
        "kind": "emit_then_exit",
        "stdout": {
          "line_count": 8,
          "line_bytes": 64
        },
        "stderr": {
          "line_count": 8,
          "line_bytes": 64
        },
        "exit_code": 23
      },
      "action": {
        "kind": "wait_for_exit"
      },
      "expected": {
        "exit_code": 23,
        "terminal_state": "failed",
        "reader_threads_joined": true,
        "pipes_closed": true
      }
    },
    {
      "id": "silent-tree-cancellation",
      "behavior": {
        "kind": "parent_with_descendant",
        "parent_mode": "silent_wait",
        "descendant_mode": "silent_wait"
      },
      "action": {
        "kind": "cancel",
        "after_ms": 100
      },
      "expected": {
        "complete_process_tree_terminated": true,
        "cleanup_within_ms": 5000,
        "reader_threads_joined": true,
        "pipes_closed": true
      }
    }
  ]
}
