# Coverage configuration for the backend product suite.
#
# The security_benchmark/ package is EVAL-ONLY and isolation-guarded
# (isolation_check.py CI-enforces that no product-runtime module imports it,
# Constitution V/XI). It runs in its own `security_benchmark/tests` suite, NOT
# in the product test invocations that produce coverage.xml — so measuring it
# as product code reports a spurious 0%. It is legitimately excluded from the
# product changed-line coverage gate; its own suite (green in CI) covers it.
[run]
omit =
    */security_benchmark/*
