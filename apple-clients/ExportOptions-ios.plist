<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Feature 053 — App Store export options for the iOS archive (which carries the
  embedded watch app, so it needs BOTH provisioning profiles).

  This is a TEMPLATE: the APPLE_TEAM_ID / APPLE_PROFILE_IOS / APPLE_PROFILE_WATCH
  placeholders are substituted at release time from CI secrets by
  Scripts/render_export_options.py. No Team ID and no profile name is committed.

  `method` is `app-store-connect`; the older `app-store` spelling is deprecated.
  `manageAppVersionAndBuildNumber` is false so App Store Connect does not rewrite
  the CI-run-derived build number the workflow stamps.
-->
<plist version="1.0">
<dict>
	<key>method</key>
	<string>app-store-connect</string>
	<key>teamID</key>
	<string>${APPLE_TEAM_ID}</string>
	<key>signingStyle</key>
	<string>manual</string>
	<key>provisioningProfiles</key>
	<dict>
		<key>com.personalailabs.astraldeep</key>
		<string>${APPLE_PROFILE_IOS}</string>
		<key>com.personalailabs.astraldeep.watch</key>
		<string>${APPLE_PROFILE_WATCH}</string>
	</dict>
	<key>manageAppVersionAndBuildNumber</key>
	<false/>
	<key>uploadSymbols</key>
	<true/>
	<key>stripSwiftSymbols</key>
	<true/>
	<key>destination</key>
	<string>export</string>
</dict>
</plist>
