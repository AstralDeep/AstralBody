<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>AstralDeep</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>AstralDeep</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>WKApplication</key>
	<true/>
	<!-- Feature 053 — the watch is an EMBEDDED COMPANION of the iOS app (it was
	     previously WKWatchOnly, which Apple defines as having no related iOS app;
	     that made WatchConnectivity, and therefore the companion-pushed server
	     override, impossible). It still installs and runs without the phone app,
	     so QR device-login remains the standalone sign-in path — which is exactly
	     why WatchConnectivity may only ever be an opportunistic optimization. -->
	<key>WKCompanionAppBundleIdentifier</key>
	<string>com.personalailabs.astraldeep</string>
	<key>WKRunsIndependentlyOfCompanionApp</key>
	<true/>
	<!-- Export compliance: standard HTTPS/OS crypto only (exempt). The iOS
	     Info.plist already declares this; the watch app is its own bundle. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>ASTRALServerBaseURL</key>
	<string>$(ASTRAL_SERVER_BASE_URL)</string>
	<key>ASTRALKeycloakAuthority</key>
	<string>$(ASTRAL_KEYCLOAK_AUTHORITY)</string>
	<!-- See the iOS Info.plist: ATS-clean; loopback only, for Debug. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
</dict>
</plist>
