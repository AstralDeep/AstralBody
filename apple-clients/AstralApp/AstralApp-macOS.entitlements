<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Feature 053 — Mac App Store requires the App Sandbox. Least privilege:
	     nothing here grants ambient filesystem or network-server access.

	     Keychain access uses the default per-app access group, so no
	     keychain-access-groups entitlement (and therefore no Keychain Sharing
	     capability) is requested. -->
	<key>com.apple.security.app-sandbox</key>
	<true/>

	<!-- Outbound HTTPS + WebSocket to the orchestrator. No network.server. -->
	<key>com.apple.security.network.client</key>
	<true/>

	<!-- A sandboxed app can only touch files the user explicitly picks, and only
	     if it says so. Two places need it, both user-initiated:
	       * ChatView's `.fileImporter` -> AppModel.stageFile(url:) reads the picked
	         file (it already brackets the read with startAccessingSecurityScopedResource)
	       * ComponentView's macOS `NSSavePanel` -> copies a downloaded component
	         export to the destination the user chose
	     Without this the pickers still open and then silently fail to read/write.
	     read-write (not read-only) because of the save panel. -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
</dict>
</plist>
