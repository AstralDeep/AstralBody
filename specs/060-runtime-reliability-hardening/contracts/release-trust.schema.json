        "ledger_entry",
        "workflow",
        "workflow_ref",
        "runner",
        "trusted_builder",
        "generated_at"
      ],
      "properties": {
        "document_type": { "const": "trusted_debt_resolution" },
        "schema_version": { "const": 1 },
        "manifest_id": { "$ref": "#/$defs/uuid" },
        "resolution_id": { "$ref": "#/$defs/uuid" },
        "exception_id": { "$ref": "#/$defs/uuid" },
