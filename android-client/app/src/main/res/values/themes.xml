<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Window/splash theme used before Compose draws (the actual app theme is
      AstralTheme in ui/theme/Theme.kt). Parented off a platform theme so no
      Material-Components XML dependency is required for a Compose-only app.
    -->
    <style name="Theme.Astral" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/astral_bg</item>
        <item name="android:statusBarColor">@color/astral_bg</item>
        <item name="android:navigationBarColor">@color/astral_bg</item>
    </style>
</resources>
