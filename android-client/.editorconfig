root = true

# ktlint configuration for the Android client (Kotlin + Jetpack Compose).
# Uses the ktlint gradle plugin (12.1.1) pinned in gradle/libs.versions.toml.
[*.kt]
# Jetpack Compose @Composable functions are PascalCase by convention (they read
# as UI elements, e.g. `AstralTopBar`, `SettingsSheet`). ktlint's function-naming
# rule otherwise flags every one of them. This is the documented, canonical way
# to make ktlint Compose-aware. (Also allow the standard @Preview test funcs.)
ktlint_function_naming_ignore_when_annotated_with = Composable, Preview

# Test source files carry long inline JSON/wire fixtures on a single line; the
# 140-column limit is not meaningful for those literals.
[**/src/{test,androidTest}/**/*.kt]
max_line_length = off
